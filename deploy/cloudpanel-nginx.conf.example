# Reference routing for one CloudPanel PHP site hosting Laravel + Astro.
# Keep the PHP location generated by CloudPanel and add the Astro proxy route
# according to the exact PHP-FPM include/socket generated for your site.

# Public Astro SSR application.
location / {
    proxy_pass http://127.0.0.1:3006;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
}

# Laravel CMS/API must remain on the PHP site routing.
location ^~ /kawruh {
    try_files $uri $uri/ /index.php?$query_string;
}

location ^~ /api {
    try_files $uri $uri/ /index.php?$query_string;
}

location ^~ /storage/ {
    try_files $uri =404;
}
