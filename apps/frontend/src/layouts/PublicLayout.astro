---
import '../styles/global.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { api, mediaUrl } from '../lib/api';
import { absoluteUrl, createWebPageSchema, resolveSiteUrl, serializeJsonLd, type JsonLd } from '../lib/seo';

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  robots?: string;
  bingSiteVerification?: string;
  googleSiteVerification?: string;
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleSection?: string;
  structuredData?: JsonLd;
};

const {
  title: providedTitle,
  description: providedDescription,
  canonicalPath = Astro.url.pathname,
  ogImage: providedOgImage,
  ogImageAlt = 'Lanyard custom dari Lanyard Depok',
  ogType = 'website',
  robots = 'index, follow',
  bingSiteVerification,
  googleSiteVerification,
  articlePublishedTime,
  articleModifiedTime,
  articleSection,
  structuredData,
} = Astro.props;

const { settings } = await api.publicSettings();
const siteUrl = resolveSiteUrl();
const title = providedTitle || settings.seo_meta_title?.trim() || settings.site_title?.trim() || 'Lanyard Depok: Cetak Custom No Worry Ongkir';
const description = providedDescription || settings.seo_meta_description?.trim() || settings.site_description?.trim() || 'Cetak lanyard custom Depok untuk kantor, sekolah, komunitas, dan event dengan proses mudah.';
const siteName = settings.site_title?.trim() || 'Lanyard Depok';
const ogImage = mediaUrl(providedOgImage || settings.og_image?.trim() || '/uploads/featured-products-showcase-lanyarddepok-v2.webp');
const faviconUrl = mediaUrl(settings.site_favicon?.trim() || '/uploads/lanyarddepok-favicon.webp');
const faviconHref = `${faviconUrl}${faviconUrl.includes('?') ? '&' : '?'}v=brand-20260711`;
const canonicalUrl = absoluteUrl(canonicalPath, siteUrl);
const ogImageUrl = absoluteUrl(ogImage, siteUrl);
const resolvedBingVerification = bingSiteVerification || settings.bing_site_verification?.trim();
const resolvedGoogleVerification = googleSiteVerification || settings.google_site_verification?.trim();
const pageStructuredData = structuredData || createWebPageSchema({
  url: canonicalUrl,
  name: title,
  description,
  imageUrl: ogImageUrl,
});
---

<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#ffffff" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/webp" href={faviconHref} />
    <link rel="shortcut icon" type="image/webp" href={faviconHref} />
    <link rel="apple-touch-icon" href={faviconHref} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    {resolvedBingVerification && <meta name="msvalidate.01" content={resolvedBingVerification} />}
    {resolvedGoogleVerification && <meta name="google-site-verification" content={resolvedGoogleVerification} />}
    {ogType === 'article' && articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {ogType === 'article' && articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
    {ogType === 'article' && articleSection && <meta property="article:section" content={articleSection} />}
    <script type="application/ld+json" set:html={serializeJsonLd(pageStructuredData)} />
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
