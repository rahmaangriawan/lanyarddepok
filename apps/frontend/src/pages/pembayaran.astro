---
import PublicLayout from '../layouts/PublicLayout.astro';
import '../styles/pembayaran.css';

export const prerender = true;

const whatsappUrl =
  'https://wa.me/6282210200700?text=Halo%20Lanyard%20Depok%2C%20saya%20ingin%20bertanya%20tentang%20pembayaran%20lanyard%20custom.';

const paymentMethods = [
  {
    name: 'Transfer Bank',
    description:
      'Lakukan pembayaran melalui transfer ke rekening bank resmi atas nama CV. Lanyard Depok Indonesia.',
    detail: 'Rekening resmi akan dikirim melalui invoice atau admin.',
  },
  {
    name: 'QRIS',
    description:
      'Bayar lebih praktis dan cepat menggunakan QR Code melalui aplikasi e-wallet atau mobile banking favorit Anda.',
    detail: 'Cocok untuk pembayaran cepat dan nominal kecil.',
  },
  {
    name: 'E-Wallet',
    description:
      'Pembayaran instan tanpa ribet melalui berbagai pilihan e-wallet populer.',
    detail: 'OVO, DANA, GoPay, ShopeePay, LinkAja.',
  },
  {
    name: 'Virtual Account',
    description:
      'Gunakan Virtual Account untuk pembayaran yang mudah dan terverifikasi otomatis.',
    detail: 'BCA, Mandiri, BNI, BRI, PermataBank.',
  },
  {
    name: 'Pembayaran Instansi',
    description:
      'Melayani pembayaran melalui invoice untuk perusahaan, instansi, sekolah, dan organisasi.',
    detail: 'Hubungi tim kami untuk informasi lebih lanjut.',
  },
];

const paymentNotes = [
  {
    title: 'Konfirmasi Pembayaran',
    description:
      'Setelah melakukan pembayaran, harap lakukan konfirmasi melalui WhatsApp atau email dengan menyertakan bukti transfer.',
  },
  {
    title: 'Pembayaran DP & Pelunasan',
    description:
      'Untuk pesanan custom dalam jumlah besar, diperlukan pembayaran DP sebelum produksi. Pelunasan dilakukan sebelum barang dikirim.',
  },
  {
    title: 'Proses Setelah Pembayaran',
    description:
      'Setelah pembayaran terkonfirmasi, tim kami akan segera memproses pesanan Anda sesuai antrian produksi.',
  },
  {
    title: 'Bukti Pembayaran',
    description:
      'Simpan bukti pembayaran hingga pesanan Anda selesai diterima untuk memudahkan pengecekan transaksi.',
  },
  {
    title: 'Atas Nama Resmi',
    description:
      'Pastikan pembayaran dilakukan ke rekening atas nama resmi perusahaan kami untuk menghindari penipuan.',
  },
  {
    title: 'Butuh Bantuan?',
    description:
      'Tim kami siap membantu Anda untuk informasi pembayaran atau kendala transaksi. Jangan ragu menghubungi kami.',
  },
];
---

<PublicLayout
  title="Pembayaran Lanyard Depok"
  description="Informasi metode pembayaran resmi untuk pemesanan lanyard custom di Lanyard Depok."
>
  <section class="border-b border-[var(--border)] bg-[#FEF9F6] px-4 py-16 text-[var(--foreground)] sm:px-6 sm:py-20 lg:px-8" style="background-color: #FEF9F6;">
    <div class="mx-auto flex max-w-4xl flex-col items-center text-center">
      <p class="inline-flex items-center gap-3 rounded-full bg-[var(--muted)] px-5 py-3 text-sm font-bold text-[var(--primary)]">
        <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18"/><path d="M7 15h4"/></svg>
        Pembayaran
      </p>

      <h1 class="mt-6 max-w-3xl text-[2.65rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[3.4rem] lg:text-[4rem]">
        Pembayaran Mudah, Aman & Terpercaya
      </h1>

      <p class="mt-6 max-w-2xl text-base leading-7 text-[var(--muted-foreground)] sm:text-lg sm:leading-8">
        Di Lanyard Depok, kami menyediakan berbagai metode pembayaran yang fleksibel untuk memudahkan proses pemesanan lanyard custom Anda.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a class="btn-primary gap-3" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
          <span>Tanya Pembayaran</span>
          <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="var(--primary-foreground)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
        </a>
      </div>

      <div class="mt-8 flex max-w-xl items-start gap-4 rounded-2xl border border-[var(--border)] bg-white/80 px-5 py-4 text-left shadow-sm">
        <span class="mt-1 h-8 w-1.5 shrink-0 rounded-full bg-[var(--secondary)]"></span>
        <p class="text-sm font-semibold leading-6 text-[var(--foreground)]">
          Semua transaksi dilindungi sistem keamanan terbaik dan data Anda dijaga kerahasiaannya.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 text-[var(--foreground)] sm:px-6 sm:py-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-[2rem] font-bold leading-tight tracking-normal text-[var(--foreground)] sm:text-[2.6rem]">
          Metode Pembayaran yang Tersedia
        </h2>
      </div>

      <div class="mt-10 overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)] shadow-[0_18px_44px_rgba(112,77,64,0.04)]">
        {paymentMethods.map((method) => (
          <article class="payment-method-row p-5 sm:p-6 lg:p-7">
            <h3 class="text-base font-bold leading-tight text-[var(--foreground)]">{method.name}</h3>
            <p class="text-sm leading-6 text-[var(--muted-foreground)]">{method.description}</p>
            <p class="text-sm font-semibold leading-6 text-[var(--primary)]">{method.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-20 text-[var(--foreground)] sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-[0_18px_44px_rgba(112,77,64,0.04)] sm:p-8 lg:p-10">
        <div class="text-center">
          <h2 class="text-[2rem] font-bold leading-tight tracking-normal text-[var(--foreground)] sm:text-[2.4rem]">
            Informasi Pembayaran
          </h2>
        </div>

        <div class="payment-info-grid mt-10">
          {paymentNotes.map((note) => (
            <article class="flex gap-4 border-t border-[var(--border)] pt-6 first:border-t-0 first:pt-0 md:[&:nth-child(2)]:border-t-0 md:[&:nth-child(2)]:pt-0">
              <span class="mt-1 grid h-8 w-8 shrink-0 place-items-center rounded-full bg-[var(--secondary)] text-[var(--primary)]">
                <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-5"/><circle cx="12" cy="12" r="9"/></svg>
              </span>
              <div class="min-w-0">
                <h3 class="text-base font-bold leading-tight text-[var(--foreground)]">{note.title}</h3>
                <p class="mt-3 text-sm leading-6 text-[var(--muted-foreground)]">{note.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
