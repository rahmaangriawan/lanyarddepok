---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { api, mediaUrl, PUBLIC_API_BASES, type Product } from '../../lib/api';
import { absoluteUrl, createCollectionPageSchema } from '../../lib/seo';
import '../../styles/produk.css';

const productsPerPage = 9;
const response = await api.products({ limit: productsPerPage });
const products = response.products;
const pagination = response.pagination;
const pageTitle = 'Produk Lanyard Custom Depok';
const pageDescription = 'Pilihan lanyard custom untuk kebutuhan kantor, event, sekolah, komunitas, dan branding di Depok.';
const stripHtml = (value?: string | null) => (value || '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const productDescription = (product: Product) => stripHtml(product.shortDescription || product.description) || 'Lanyard custom berkualitas untuk kebutuhan brand dan kegiatan Anda.';
const productCollectionSchema = createCollectionPageSchema({
  url: absoluteUrl('/produk'),
  name: pageTitle,
  description: pageDescription,
  items: products.map((product) => ({
    name: product.name || product.sku,
    url: absoluteUrl(`/produk/${encodeURIComponent(product.slug || product.sku)}`),
    imageUrl: absoluteUrl(mediaUrl(product.featuredImage)),
  })),
});
---

<PublicLayout title={pageTitle} description={pageDescription} canonicalPath="/produk" structuredData={productCollectionSchema}>
  <section
    class="border-b border-[var(--border)] bg-white py-16 text-[var(--foreground)] sm:py-20"
    data-product-browser
    data-api-bases={JSON.stringify(PUBLIC_API_BASES)}
    data-current-page={pagination.current_page}
    data-last-page={pagination.last_page}
    data-total={pagination.total}
    data-per-page={productsPerPage}
  >
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="section-eyebrow">Produk</p>
        <h1 class="section-title mt-5">Pilihan Lanyard Custom</h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-[var(--muted-foreground)]">Temukan model lanyard berdasarkan nama, SKU, spesifikasi, atau kebutuhan aksesoris.</p>
      </div>

      <form class="mt-9 flex max-w-2xl gap-3" role="search" data-product-search-form>
        <label class="sr-only" for="productSearch">Cari produk</label>
        <input
          id="productSearch"
          class="min-h-12 min-w-0 flex-1 rounded-xl border border-[var(--border)] bg-white px-4 text-sm text-[var(--foreground)] outline-none transition placeholder:text-[var(--muted-foreground)] focus:border-[var(--primary)] focus:ring-2 focus:ring-[color-mix(in_srgb,var(--primary)_16%,transparent)]"
          type="search"
          name="q"
          placeholder="Cari nama produk, SKU, atau spesifikasi..."
          autocomplete="off"
          data-product-search
        />
        <button class="min-h-12 shrink-0 rounded-xl bg-[var(--primary)] px-5 text-sm font-bold text-white transition hover:opacity-90 active:translate-y-px" type="submit">Cari</button>
      </form>

      <div class="mt-5 flex min-h-6 items-center justify-between gap-4 text-sm text-[var(--muted-foreground)]" aria-live="polite">
        <p data-product-status>
          {pagination.total > 0 ? `Menampilkan ${products.length} dari ${pagination.total} produk` : 'Belum ada produk tersedia'}
        </p>
        <button class="hidden font-bold text-[var(--primary)] underline underline-offset-4" type="button" data-clear-search>Hapus pencarian</button>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3" data-product-grid aria-busy="false">
        {products.map((product) => (
          <a href={`/produk/${encodeURIComponent(product.slug || product.sku)}`} class="product-list-card group flex min-h-full flex-col overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--card)] transition hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--primary)_42%,var(--border))]">
            <div class="overflow-hidden bg-[var(--muted)]">
              <img class="aspect-[16/10] w-full object-cover transition duration-300 group-hover:scale-[1.02]" src={mediaUrl(product.featuredImage)} alt={product.name || product.sku} loading="lazy" decoding="async" />
            </div>
            <div class="flex flex-1 flex-col p-5">
              <div class="flex items-center justify-between gap-3 text-xs font-bold text-[var(--primary)]">
                <span>{product.category?.name || 'Lanyard Custom'}</span>
                <span>{product.sku}</span>
              </div>
              <h2 class="mt-3 text-xl font-bold leading-snug text-[var(--foreground)]">{product.name || product.sku}</h2>
              <p class="product-list-card__description mt-3 text-sm leading-6 text-[var(--muted-foreground)]">{productDescription(product)}</p>
              {product.basePrice && <p class="mt-auto pt-5 text-sm font-bold text-[var(--foreground)]">{product.basePrice}</p>}
            </div>
          </a>
        ))}
      </div>

      <div class:list={['mt-12 text-center', products.length > 0 && 'hidden']} data-product-empty>
        <h2 class="text-xl font-bold text-[var(--foreground)]">Produk tidak ditemukan</h2>
        <p class="mt-2 text-sm text-[var(--muted-foreground)]">Coba gunakan nama, SKU, atau kata kunci yang berbeda.</p>
      </div>

      <div class:list={['mt-12 flex justify-center', pagination.current_page >= pagination.last_page && 'hidden']} data-load-more-wrap>
        <button class="min-h-12 rounded-xl border border-[var(--primary)] px-6 text-sm font-bold text-[var(--primary)] transition hover:bg-[var(--primary)] hover:text-white active:translate-y-px disabled:cursor-wait disabled:opacity-60" type="button" data-load-more>
          Muat lebih banyak
        </button>
      </div>
    </div>
  </section>
</PublicLayout>

<style>
  .product-list-card__description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }
</style>

<script>
  const productBrowser = document.querySelector('[data-product-browser]');

  if (productBrowser) {
    const grid = productBrowser.querySelector('[data-product-grid]');
    const searchForm = productBrowser.querySelector('[data-product-search-form]');
    const searchInput = productBrowser.querySelector('[data-product-search]');
    const clearSearch = productBrowser.querySelector('[data-clear-search]');
    const status = productBrowser.querySelector('[data-product-status]');
    const empty = productBrowser.querySelector('[data-product-empty]');
    const loadMoreWrap = productBrowser.querySelector('[data-load-more-wrap]');
    const loadMore = productBrowser.querySelector('[data-load-more]');
    const apiBases = JSON.parse(productBrowser.getAttribute('data-api-bases') || '[]');
    const perPage = Number(productBrowser.getAttribute('data-per-page') || '9');
    let currentPage = Number(productBrowser.getAttribute('data-current-page') || '1');
    let lastPage = Number(productBrowser.getAttribute('data-last-page') || '1');
    let total = Number(productBrowser.getAttribute('data-total') || '0');
    let currentQuery = '';
    let activeApiBase = apiBases[0] || '/api';
    let debounceId;
    let requestController;

    const plainText = (value) => {
      const documentValue = new DOMParser().parseFromString(String(value || ''), 'text/html');
      return (documentValue.body.textContent || '').replace(/\s+/g, ' ').trim();
    };

    const resolveMedia = (value) => {
      const path = value || '/uploads/featured-products-showcase-lanyarddepok-v2.webp';
      if (/^(https?:)?\/\//i.test(path) || path.startsWith('data:')) return path;
      if (/^\/(storage|uploads|media|images)\//.test(path)) {
        try {
          return new URL(path, activeApiBase.replace(/\/api\/?$/, '')).toString();
        } catch {
          return path;
        }
      }
      return path.startsWith('/') ? path : `/${path}`;
    };

    const createProductCard = (product) => {
      const card = document.createElement('a');
      const identifier = product.slug || product.sku;
      card.href = `/produk/${encodeURIComponent(identifier)}`;
      card.className = 'product-list-card group flex min-h-full flex-col overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--card)] transition hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--primary)_42%,var(--border))]';

      const media = document.createElement('div');
      media.className = 'overflow-hidden bg-[var(--muted)]';
      const image = document.createElement('img');
      image.className = 'aspect-[16/10] w-full object-cover transition duration-300 group-hover:scale-[1.02]';
      image.src = resolveMedia(product.featuredImage);
      image.alt = product.name || product.sku;
      image.loading = 'lazy';
      image.decoding = 'async';
      media.appendChild(image);

      const body = document.createElement('div');
      body.className = 'flex flex-1 flex-col p-5';
      const meta = document.createElement('div');
      meta.className = 'flex items-center justify-between gap-3 text-xs font-bold text-[var(--primary)]';
      const category = document.createElement('span');
      category.textContent = product.category?.name || 'Lanyard Custom';
      const sku = document.createElement('span');
      sku.textContent = product.sku;
      meta.append(category, sku);

      const title = document.createElement('h2');
      title.className = 'mt-3 text-xl font-bold leading-snug text-[var(--foreground)]';
      title.textContent = product.name || product.sku;
      const description = document.createElement('p');
      description.className = 'product-list-card__description mt-3 text-sm leading-6 text-[var(--muted-foreground)]';
      description.textContent = plainText(product.shortDescription || product.description) || 'Lanyard custom berkualitas untuk kebutuhan brand dan kegiatan Anda.';
      body.append(meta, title, description);

      if (product.basePrice) {
        const price = document.createElement('p');
        price.className = 'mt-auto pt-5 text-sm font-bold text-[var(--foreground)]';
        price.textContent = product.basePrice;
        body.appendChild(price);
      }

      card.append(media, body);
      return card;
    };

    const updateState = () => {
      const loaded = grid?.children.length || 0;
      if (status) status.textContent = total > 0 ? `Menampilkan ${loaded} dari ${total} produk` : (currentQuery ? 'Tidak ada produk yang cocok' : 'Belum ada produk tersedia');
      empty?.classList.toggle('hidden', loaded > 0);
      loadMoreWrap?.classList.toggle('hidden', loaded === 0 || currentPage >= lastPage);
      clearSearch?.classList.toggle('hidden', currentQuery === '');
    };

    const requestProducts = async (page, append) => {
      requestController?.abort();
      requestController = new AbortController();
      grid?.setAttribute('aria-busy', 'true');
      if (status) status.textContent = currentQuery ? 'Mencari produk...' : 'Memuat produk...';
      if (loadMore) {
        loadMore.disabled = true;
        loadMore.textContent = 'Memuat...';
      }

      const params = new URLSearchParams({ limit: String(perPage), page: String(page) });
      if (currentQuery) params.set('q', currentQuery);

      try {
        let payload;
        for (const base of apiBases) {
          try {
            const response = await fetch(`${base}/products?${params.toString()}`, { headers: { Accept: 'application/json' }, signal: requestController.signal });
            if (!response.ok) continue;
            payload = await response.json();
            activeApiBase = base;
            break;
          } catch (error) {
            if (error instanceof DOMException && error.name === 'AbortError') throw error;
          }
        }
        if (!payload) throw new Error('Produk gagal dimuat');

        if (!append && grid) grid.innerHTML = '';
        (payload.products || []).forEach((product) => grid?.appendChild(createProductCard(product)));
        currentPage = Number(payload.pagination?.current_page || page);
        lastPage = Number(payload.pagination?.last_page || 1);
        total = Number(payload.pagination?.total || 0);
        updateState();
      } catch (error) {
        if (!(error instanceof DOMException && error.name === 'AbortError') && status) {
          status.textContent = 'Produk gagal dimuat. Silakan coba lagi.';
        }
      } finally {
        grid?.setAttribute('aria-busy', 'false');
        if (loadMore) {
          loadMore.disabled = false;
          loadMore.textContent = 'Muat lebih banyak';
        }
      }
    };

    const runSearch = () => {
      currentQuery = searchInput?.value.trim() || '';
      currentPage = 1;
      requestProducts(1, false);
    };

    searchForm?.addEventListener('submit', (event) => {
      event.preventDefault();
      window.clearTimeout(debounceId);
      runSearch();
    });
    searchInput?.addEventListener('input', () => {
      window.clearTimeout(debounceId);
      debounceId = window.setTimeout(runSearch, 350);
    });
    clearSearch?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      runSearch();
      searchInput?.focus();
    });
    loadMore?.addEventListener('click', () => {
      if (currentPage < lastPage) requestProducts(currentPage + 1, true);
    });
    updateState();
  }
</script>
