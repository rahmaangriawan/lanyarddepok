---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { api, mediaUrl } from '../../lib/api';
import { absoluteUrl, createProductSchema } from '../../lib/seo';
import '../../styles/produk.css';

export const prerender = false;

const slug = Astro.params.slug || '';
const [{ product }, { settings }] = await Promise.all([
  api.product(slug),
  api.publicSettings(),
]);

if (!product) return Astro.redirect('/produk', 302);

const stripHtml = (value?: string | null) => (value || '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const productName = product.name || product.sku || 'Produk Lanyard';
const shortDescription = stripHtml(product.shortDescription || product.shortDesc || product.metaDescription || product.description || product.longDesc)
  || 'Lanyard custom untuk kebutuhan perusahaan, acara, sekolah, dan komunitas.';
const productUrl = absoluteUrl(`/produk/${encodeURIComponent(slug)}`);
const productImage = mediaUrl(product.featuredImage);
const productSchema = createProductSchema({
  url: productUrl,
  name: productName,
  description: shortDescription,
  imageUrl: absoluteUrl(productImage),
  sku: product.sku,
  category: product.category?.name,
});
const whatsappNumber = (settings.contact_whatsapp || settings.contact_phone || '6282210200700').replace(/\D/g, '').replace(/^0/, '62');
const whatsappMessage = encodeURIComponent(`Halo admin, saya ingin pesan ${productName}. Apakah masih tersedia?`);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<PublicLayout
  title={product.metaTitle || productName}
  description={product.metaDescription || shortDescription}
  canonicalPath={`/produk/${encodeURIComponent(slug)}`}
  ogImage={productImage}
  ogImageAlt={productName}
  structuredData={productSchema}
>
  <article class="bg-white py-10 text-[var(--foreground)] sm:py-14 lg:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.05fr)_minmax(22rem,0.95fr)] lg:items-center lg:gap-14">
          <div class="overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--muted)]">
            <img
              class="aspect-square w-full bg-white object-contain p-4 sm:p-7"
              src={productImage}
              alt={productName}
              fetchpriority="high"
              decoding="async"
            />
          </div>

          <div class="min-w-0">
            <h1 class="text-[2rem] font-bold leading-[1.15] tracking-normal sm:text-[2.5rem] lg:text-[2.75rem]">{productName}</h1>

            <div class="mt-6">
              <p class="text-sm font-semibold text-[var(--muted-foreground)]">Harga</p>
              <p class="mt-1 text-3xl font-bold leading-tight">{product.basePrice || 'Hubungi admin'}</p>
            </div>

            <p class="mt-5 text-base leading-7 text-[var(--muted-foreground)] sm:text-lg sm:leading-8">{shortDescription}</p>

            {product.variants && product.variants.length > 0 && (
              <div class="mt-6">
                <p class="text-sm font-bold">Pilihan varian</p>
                <div class="mt-3 flex flex-wrap gap-2">
                  {product.variants.map((variant) => (
                    <span class="rounded-lg border border-[var(--border)] px-3 py-2 text-sm font-semibold text-[var(--foreground)]">{variant}</span>
                  ))}
                </div>
              </div>
            )}

            <a class="mt-8 inline-flex min-h-12 w-full items-center justify-center rounded-xl bg-[var(--primary)] px-6 text-center text-sm font-bold text-white transition hover:opacity-90 active:translate-y-px sm:w-auto" href={whatsappUrl} target="_blank" rel="noopener noreferrer">Pesan Sekarang</a>
          </div>
      </div>
    </div>
  </article>
</PublicLayout>
