---
import PublicLayout from '../layouts/PublicLayout.astro';
import '../styles/pengiriman.css';

export const prerender = true;

const whatsappUrl =
  'https://wa.me/6282210200700?text=Halo%20Lanyard%20Depok%2C%20saya%20ingin%20bertanya%20tentang%20pengiriman%20lanyard%20custom.';

const heroBenefits = [
  {
    title: 'Pengemasan Aman',
    description: 'Produk dikemas rapi dan aman untuk melindungi kualitas selama pengiriman.',
    icon: 'shield',
  },
  {
    title: 'Proses Cepat',
    description: 'Pesanan diproses sesuai estimasi waktu yang telah disepakati.',
    icon: 'clock',
  },
  {
    title: 'Informasi Jelas',
    description: 'Resi pengiriman akan kami kirimkan setelah pesanan diserahkan ke ekspedisi.',
    icon: 'receipt',
  },
];

const expeditions = [
  {
    name: 'JNE',
    description: 'Layanan pengiriman ke seluruh Indonesia dengan jangkauan luas.',
    estimate: '1-4 hari kerja',
  },
  {
    name: 'J&T Express',
    description: 'Pengiriman cepat dengan jaringan yang terus berkembang.',
    estimate: '1-3 hari kerja',
  },
  {
    name: 'SiCepat Ekspres',
    description: 'Layanan pengiriman cepat dan terjangkau ke berbagai wilayah.',
    estimate: '1-3 hari kerja',
  },
];

const shippingSteps = [
  {
    title: 'Pesanan Diproses',
    description: 'Pesanan Anda diproses setelah pembayaran terkonfirmasi.',
  },
  {
    title: 'Produksi',
    description: 'Lanyard diproduksi sesuai desain dan spesifikasi yang disetujui.',
  },
  {
    title: 'Dikirim ke Ekspedisi',
    description: 'Pesanan dikemas dengan aman dan diserahkan ke ekspedisi.',
  },
  {
    title: 'Pesanan Diterima',
    description: 'Pesanan sampai di alamat tujuan dengan aman dan tepat waktu.',
  },
];

const importantInfo = [
  {
    title: 'Waktu Operasional',
    description: 'Senin - Sabtu, kecuali hari libur nasional. Order diproses sesuai jam layanan.',
  },
  {
    title: 'Cek Resi',
    description: 'Nomor resi dapat dicek melalui website resmi masing-masing ekspedisi atau admin kami.',
  },
  {
    title: 'Kendala Pengiriman',
    description: 'Jika terjadi kendala pada pengiriman, tim kami akan membantu koordinasi dengan pihak ekspedisi.',
  },
  {
    title: 'Alamat Pengiriman',
    description: 'Pastikan alamat, nama penerima, dan nomor telepon sudah benar sebelum pesanan dikirim.',
  },
];
---

<PublicLayout
  title="Pengiriman Lanyard Depok"
  description="Informasi pengiriman pesanan lanyard custom Lanyard Depok, pilihan ekspedisi, estimasi, alur, dan catatan penting."
>
  <section class="border-b border-[var(--border)] bg-[#FEF9F6] px-4 py-16 text-[var(--foreground)] sm:px-6 sm:py-20 lg:px-8" style="background-color: #FEF9F6;">
    <div class="mx-auto grid max-w-7xl items-center gap-10 lg:grid-cols-[0.92fr_1.08fr] lg:gap-16">
      <div class="min-w-0">
        <p class="inline-flex items-center gap-3 rounded-full bg-[var(--muted)] px-5 py-3 text-sm font-bold text-[var(--primary)]">
          <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17H5V6h10v11h-1"/><path d="M15 9h3l3 4v4h-3"/><circle cx="7" cy="17" r="2"/><circle cx="18" cy="17" r="2"/></svg>
          Pengiriman
        </p>

        <h1 class="mt-6 max-w-xl text-[2.65rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[3.4rem] lg:text-[4rem]">
          Kirim Cepat, Sampai Tepat
        </h1>

        <p class="mt-6 max-w-xl text-base leading-7 text-[var(--muted-foreground)] sm:text-lg sm:leading-8">
          Kami memastikan setiap pesanan lanyard custom Anda dikirim dengan aman, cepat, dan tepat waktu. Kepuasan Anda adalah prioritas kami.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn-primary gap-3" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
            <span>Tanya Pengiriman</span>
            <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="var(--primary-foreground)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-[0_18px_44px_rgba(112,77,64,0.04)] sm:p-7 lg:p-8">
        <div class="grid gap-6">
          {heroBenefits.map((benefit) => (
            <article class="shipping-benefit-card">
              <span class="grid h-14 w-14 shrink-0 place-items-center rounded-full bg-[var(--primary)] text-[var(--primary-foreground)]">
                {benefit.icon === 'shield' && (
                  <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V5l8-3 8 3z"/><path d="m9 12 2 2 4-5"/></svg>
                )}
                {benefit.icon === 'clock' && (
                  <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
                )}
                {benefit.icon === 'receipt' && (
                  <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3h10v18l-2-1-2 1-2-1-2 1-2-1z"/><path d="M9 8h6"/><path d="M9 12h6"/><path d="M9 16h4"/></svg>
                )}
              </span>
              <div class="min-w-0">
                <h2 class="text-base font-bold leading-tight text-[var(--foreground)]">{benefit.title}</h2>
                <p class="mt-2 text-sm leading-6 text-[var(--muted-foreground)]">{benefit.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 py-16 text-[var(--foreground)] sm:px-6 sm:py-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-[2rem] font-bold leading-tight tracking-normal text-[var(--foreground)] sm:text-[2.6rem]">
          Pilihan Ekspedisi
        </h2>
      </div>

      <div class="mt-10 grid gap-5 md:grid-cols-3">
        {expeditions.map((expedition) => (
          <article class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-[0_18px_44px_rgba(112,77,64,0.04)] sm:p-6">
            <h3 class="text-xl font-bold leading-tight text-[var(--foreground)]">{expedition.name}</h3>
            <p class="mt-4 min-h-[3.5rem] text-sm leading-6 text-[var(--muted-foreground)]">{expedition.description}</p>
            <div class="mt-6 border-t border-[var(--border)] pt-5">
              <p class="text-xs font-bold uppercase leading-5 text-[var(--primary)]">Estimasi Pengiriman</p>
              <p class="mt-1 text-base font-extrabold leading-tight text-[var(--foreground)]">{expedition.estimate}</p>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-5 flex items-start gap-4 rounded-2xl border border-[var(--border)] bg-[var(--muted)] px-5 py-4">
        <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-white text-[var(--primary)]">
          <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8h.01"/><path d="M11 12h1v4h1"/></svg>
        </span>
        <p class="text-sm font-semibold leading-6 text-[var(--foreground)]">
          Catatan: Estimasi pengiriman dapat berubah tergantung lokasi tujuan, kondisi cuaca, dan kebijakan dari pihak ekspedisi.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-16 text-[var(--foreground)] sm:px-6 sm:pb-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-[2rem] font-bold leading-tight tracking-normal text-[var(--foreground)] sm:text-[2.4rem]">
          Alur Pengiriman
        </h2>
      </div>

      <div class="shipping-timeline mt-10">
        {shippingSteps.map((step, index) => (
          <article class="shipping-timeline-item rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 text-center shadow-[0_18px_44px_rgba(112,77,64,0.04)] md:border-0 md:bg-transparent md:p-0 md:shadow-none">
            <span class="relative z-10 mx-auto grid h-14 w-14 place-items-center rounded-full bg-[var(--muted)] text-xl font-extrabold text-[var(--primary)]">
              {index + 1}
            </span>
            <h3 class="mt-5 text-base font-bold leading-tight text-[var(--foreground)]">{step.title}</h3>
            <p class="mx-auto mt-3 max-w-[13rem] text-sm leading-6 text-[var(--muted-foreground)]">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white px-4 pb-20 text-[var(--foreground)] sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <h2 class="text-[2rem] font-bold leading-tight tracking-normal text-[var(--foreground)] sm:text-[2.4rem]">
          Informasi Penting
        </h2>
      </div>

      <div class="mt-10 rounded-2xl border border-[var(--border)] bg-[var(--card)] p-5 shadow-[0_18px_44px_rgba(112,77,64,0.04)] sm:p-7 lg:p-8">
        <div class="shipping-info-grid">
          {importantInfo.map((info) => (
            <article>
              <h3 class="text-base font-bold leading-tight text-[var(--foreground)]">{info.title}</h3>
              <p class="mt-3 text-sm leading-6 text-[var(--muted-foreground)]">{info.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>
</PublicLayout>
