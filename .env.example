# Database CloudPanel / MariaDB / MySQL
# Format:
# mysql://USER:PASSWORD@HOST:PORT/DATABASE?connection_limit=20
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@127.0.0.1:3306/lanyarddepok?connection_limit=20"

# Wajib di production. Buat random panjang minimal 32 karakter.
# Contoh generate:
# openssl rand -base64 48
JWT_SECRET="ganti-dengan-random-secret-yang-panjang"

# URL domain production, tanpa slash di belakang.
NEXT_PUBLIC_SITE_URL="https://lanyarddepok.com"
SITE_URL="https://lanyarddepok.com"

# Port Node.js app di CloudPanel.
PORT=3006
NODE_ENV="production"
TZ="Asia/Jakarta"

# Security headers.
# Default app enforcing CSP. Isi true sementara jika perlu observasi report-only.
CSP_REPORT_ONLY="false"

# Register admin publik default dimatikan.
# Isi true hanya kalau benar-benar perlu membuka endpoint /api/auth/register.
AUTH_PUBLIC_REGISTER_ENABLED="false"

# Google Search Console verification, opsional.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# Cloudflare Turnstile, opsional.
# Jika kosong, form tetap jalan tanpa validasi Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Product/site key opsional kalau nanti dipakai untuk visibility/config produk.
PRODUCT_SITE_KEY=""
NEXT_PUBLIC_PRODUCT_SITE_KEY=""
NEXT_PUBLIC_SITE_KEY=""

# Build-only. Jangan isi true di runtime production biasa.
SKIP_DB_DURING_BUILD="false"
