---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { api, mediaUrl, type Product } from '../../lib/api';
import { absoluteUrl, createProductSchema } from '../../lib/seo';
import '../../styles/produk.css';

export const prerender = false;

const slug = Astro.params.slug || '';
const [{ product }, relatedResponse, { settings }] = await Promise.all([
  api.product(slug),
  api.products({ limit: 6 }),
  api.publicSettings(),
]);

if (!product) return Astro.redirect('/produk', 302);

const stripHtml = (value?: string | null) => (value || '').replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const productName = product.name || product.sku || 'Produk Lanyard';
const richDescription = product.description || product.longDesc || '';
const shortDescription = stripHtml(product.shortDescription || product.shortDesc || product.metaDescription || richDescription)
  || 'Lanyard custom untuk kebutuhan perusahaan, acara, sekolah, dan komunitas.';
const productUrl = absoluteUrl(`/produk/${encodeURIComponent(slug)}`);
const productImage = mediaUrl(product.featuredImage);
const productSchema = createProductSchema({
  url: productUrl,
  name: productName,
  description: stripHtml(richDescription || shortDescription),
  imageUrl: absoluteUrl(productImage),
  sku: product.sku,
  category: product.category?.name,
});
const whatsappNumber = (settings.contact_whatsapp || settings.contact_phone || '6282210200700').replace(/\D/g, '').replace(/^0/, '62');
const whatsappMessage = encodeURIComponent(`Halo Lanyard Depok, saya ingin meminta penawaran untuk ${productName}${product.sku ? ` (SKU ${product.sku})` : ''}.`);
const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
const productFacts = [
  { label: 'SKU', value: product.sku },
  { label: 'Kategori', value: product.category?.name || 'Lanyard Custom' },
  { label: 'Minimum order', value: product.minOrder },
].filter((item) => item.value);
const detailGroups = [
  { title: 'Spesifikasi', content: product.specs },
  { title: 'Aksesori', content: product.accessories },
].filter((item) => item.content);
const relatedProducts = relatedResponse.products
  .filter((item) => item.id !== product.id && (item.slug || item.sku) !== (product.slug || product.sku))
  .slice(0, 3);
const relatedDescription = (item: Product) => stripHtml(item.shortDescription || item.description)
  || 'Lanyard custom untuk kebutuhan identitas dan promosi.';
---

<PublicLayout
  title={product.metaTitle || productName}
  description={product.metaDescription || shortDescription}
  canonicalPath={`/produk/${encodeURIComponent(slug)}`}
  ogImage={productImage}
  ogImageAlt={productName}
  structuredData={productSchema}
>
  <article class="bg-white text-[var(--foreground)]">
    <section class="border-b border-[var(--border)] py-8 sm:py-10 lg:py-14">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <nav aria-label="Breadcrumb" class="mb-7 flex flex-wrap items-center gap-2 text-sm text-[var(--muted-foreground)]">
          <a class="transition hover:text-[var(--primary)]" href="/">Beranda</a>
          <span aria-hidden="true">/</span>
          <a class="transition hover:text-[var(--primary)]" href="/produk">Produk</a>
          <span aria-hidden="true">/</span>
          <span class="max-w-[18rem] truncate font-semibold text-[var(--foreground)]" aria-current="page">{productName}</span>
        </nav>

        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.08fr)_minmax(24rem,0.92fr)] lg:items-start lg:gap-14">
          <div class="product-gallery overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--muted)]">
            <img
              class="aspect-square w-full bg-white object-contain p-4 sm:p-7"
              src={productImage}
              alt={productName}
              fetchpriority="high"
              decoding="async"
            />
          </div>

          <div class="min-w-0 lg:sticky lg:top-24">
            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm font-semibold text-[var(--muted-foreground)]">
              <span class="text-[var(--primary)]">{product.category?.name || 'Lanyard Custom'}</span>
              {product.sku && <span>SKU {product.sku}</span>}
            </div>
            <h1 class="mt-4 text-[2rem] font-bold leading-[1.15] tracking-normal sm:text-[2.5rem] lg:text-[2.75rem]">{productName}</h1>
            <p class="mt-5 text-base leading-7 text-[var(--muted-foreground)] sm:text-lg sm:leading-8">{shortDescription}</p>

            <div class="mt-7 border-y border-[var(--border)] py-6">
              <p class="text-sm font-semibold text-[var(--muted-foreground)]">Harga dasar</p>
              <p class="mt-1 text-3xl font-bold leading-tight text-[var(--foreground)]">{product.basePrice || 'Hubungi kami'}</p>
              <p class="mt-2 text-sm leading-6 text-[var(--muted-foreground)]">Harga akhir menyesuaikan jumlah, bahan, ukuran, aksesori, dan desain.</p>
            </div>

            {productFacts.length > 0 && (
              <dl class="mt-6 grid grid-cols-2 gap-x-6 gap-y-5 sm:grid-cols-3">
                {productFacts.map((item) => (
                  <div class="min-w-0">
                    <dt class="text-xs font-semibold text-[var(--muted-foreground)]">{item.label}</dt>
                    <dd class="mt-1 break-words text-sm font-bold leading-6 text-[var(--foreground)]">{item.value}</dd>
                  </div>
                ))}
              </dl>
            )}

            <div class="mt-8 grid gap-3 sm:grid-cols-2">
              <a class="inline-flex min-h-12 items-center justify-center rounded-xl bg-[var(--primary)] px-5 text-center text-sm font-bold text-white transition hover:opacity-90 active:translate-y-px" href={whatsappUrl} target="_blank" rel="noopener noreferrer">Minta penawaran</a>
              <a class="inline-flex min-h-12 items-center justify-center rounded-xl border border-[var(--border)] px-5 text-center text-sm font-bold text-[var(--foreground)] transition hover:border-[var(--primary)] hover:text-[var(--primary)]" href="#detail-produk">Lihat detail produk</a>
            </div>

            <p class="mt-5 text-sm leading-6 text-[var(--muted-foreground)]">Tim kami akan membantu pengecekan spesifikasi dan menyiapkan quotation sebelum produksi.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="detail-produk" class="scroll-mt-24 border-b border-[var(--border)] py-14 sm:py-18 lg:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.65fr)] lg:gap-16 lg:px-8">
        <div class="min-w-0">
          <h2 class="text-2xl font-bold leading-tight sm:text-3xl">Detail produk</h2>
          {richDescription ? (
            <div class="product-description mt-6" set:html={richDescription} />
          ) : (
            <p class="mt-6 text-base leading-8 text-[var(--muted-foreground)]">{shortDescription}</p>
          )}
        </div>

        <aside class="min-w-0 lg:border-l lg:border-[var(--border)] lg:pl-10">
          <h2 class="text-xl font-bold leading-tight">Informasi produk</h2>
          {detailGroups.length > 0 ? (
            <div class="mt-5 space-y-7">
              {detailGroups.map((item) => (
                <section>
                  <h3 class="text-sm font-bold text-[var(--foreground)]">{item.title}</h3>
                  <p class="mt-2 whitespace-pre-line text-sm leading-7 text-[var(--muted-foreground)]">{item.content}</p>
                </section>
              ))}
            </div>
          ) : (
            <p class="mt-4 text-sm leading-7 text-[var(--muted-foreground)]">Konsultasikan kebutuhan ukuran, bahan, dan aksesori kepada tim kami.</p>
          )}
          <a class="mt-7 inline-flex min-h-11 w-full items-center justify-center rounded-xl border border-[var(--primary)] px-4 text-center text-sm font-bold text-[var(--primary)] transition hover:bg-[var(--primary)] hover:text-white" href={whatsappUrl} target="_blank" rel="noopener noreferrer">Tanyakan spesifikasi</a>
        </aside>
      </div>
    </section>

    {relatedProducts.length > 0 && (
      <section class="py-14 sm:py-18 lg:py-20">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="max-w-2xl">
            <h2 class="text-2xl font-bold leading-tight sm:text-3xl">Produk lainnya</h2>
            <p class="mt-3 text-base leading-7 text-[var(--muted-foreground)]">Bandingkan pilihan lain sebelum menentukan spesifikasi pesanan.</p>
          </div>
          <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
            {relatedProducts.map((item) => (
              <a class="group flex min-h-full flex-col overflow-hidden rounded-xl border border-[var(--border)] bg-white transition hover:-translate-y-0.5 hover:border-[var(--primary)]" href={`/produk/${encodeURIComponent(item.slug || item.sku)}`}>
                <div class="overflow-hidden bg-[var(--muted)]">
                  <img class="aspect-[16/10] w-full object-cover transition duration-300 group-hover:scale-[1.02]" src={mediaUrl(item.featuredImage)} alt={item.name || item.sku} loading="lazy" decoding="async" />
                </div>
                <div class="flex flex-1 flex-col p-5">
                  <p class="text-xs font-bold text-[var(--primary)]">{item.sku}</p>
                  <h3 class="mt-2 text-lg font-bold leading-snug">{item.name || item.sku}</h3>
                  <p class="related-description mt-3 text-sm leading-6 text-[var(--muted-foreground)]">{relatedDescription(item)}</p>
                  <p class="mt-auto pt-5 text-sm font-bold">{item.basePrice || 'Minta penawaran'}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</PublicLayout>

<style>
  .product-gallery {
    box-shadow: 0 18px 45px rgb(59 42 34 / 8%);
  }

  .product-description {
    color: var(--muted-foreground);
    font-size: 1rem;
    line-height: 1.9;
  }

  .product-description :global(h1),
  .product-description :global(h2),
  .product-description :global(h3),
  .product-description :global(h4) {
    color: var(--foreground);
    font-weight: 700;
    letter-spacing: 0;
    line-height: 1.3;
    margin: 2rem 0 0.75rem;
  }

  .product-description :global(h1),
  .product-description :global(h2) { font-size: 1.5rem; }
  .product-description :global(h3),
  .product-description :global(h4) { font-size: 1.2rem; }
  .product-description :global(p) { margin: 0 0 1rem; }
  .product-description :global(ul) { list-style: disc; }
  .product-description :global(ol) { list-style: decimal; }
  .product-description :global(ul),
  .product-description :global(ol) { margin: 1rem 0; padding-left: 1.5rem; }
  .product-description :global(li) { margin: 0.45rem 0; padding-left: 0.2rem; }
  .product-description :global(li)::marker { color: var(--primary); font-weight: 700; }
  .product-description :global(strong) { color: var(--foreground); font-weight: 700; }
  .product-description :global(a) { color: var(--primary); font-weight: 700; text-decoration: underline; text-underline-offset: 3px; }
  .product-description :global(img) { border-radius: 0.75rem; height: auto; margin: 1.5rem 0; max-width: 100%; }

  .related-description {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  @media (max-width: 767px) {
    .product-description { line-height: 1.8; }
  }
</style>
