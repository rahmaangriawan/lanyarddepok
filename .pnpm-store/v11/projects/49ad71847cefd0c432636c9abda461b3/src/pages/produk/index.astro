---
import PublicLayout from '../../layouts/PublicLayout.astro';
import { api, mediaUrl } from '../../lib/api';
import { absoluteUrl, createCollectionPageSchema } from '../../lib/seo';
import '../../styles/produk.css';

const { products } = await api.products();
const pageTitle = 'Produk Lanyard Custom Depok';
const pageDescription = 'Pilihan lanyard custom untuk kebutuhan kantor, event, sekolah, komunitas, dan branding di Depok.';
const productCollectionSchema = createCollectionPageSchema({
  url: absoluteUrl('/produk'),
  name: pageTitle,
  description: pageDescription,
  items: products.map((product) => ({
    name: product.name || product.sku,
    url: absoluteUrl(`/produk/${encodeURIComponent(product.slug || product.sku)}`),
    imageUrl: absoluteUrl(mediaUrl(product.featuredImage)),
  })),
});
---

<PublicLayout title={pageTitle} description={pageDescription} canonicalPath="/produk" structuredData={productCollectionSchema}>
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="section-eyebrow">Produk</p>
      <h1 class="section-title mt-5">Pilihan Lanyard Custom</h1>
      <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {products.map((product) => (
          <a href={`/produk/${product.slug || product.sku}`} class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-4">
            <img class="h-56 w-full rounded-xl object-cover" src={mediaUrl(product.featuredImage)} alt={product.name || product.sku} loading="lazy" decoding="async" />
            <h2 class="mt-5 text-xl font-bold">{product.name}</h2>
            <p class="mt-2 text-sm leading-6 text-[var(--muted-foreground)]">{product.shortDescription || product.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</PublicLayout>
