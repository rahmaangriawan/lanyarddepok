          <p class="max-w-none whitespace-nowrap text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary-foreground)]/80 sm:max-w-40 sm:whitespace-normal">Kenapa Memilih Lanyard Depok?</p>
          <h2 class="max-w-sm text-[1.7rem] font-bold leading-[1.08] tracking-normal sm:text-[2.4rem] lg:text-[2.4rem]">Kualitas yang terlihat, pelayanan yang terasa.</h2>
          <p class="max-w-sm text-sm font-medium leading-6 text-[var(--primary-foreground)]/85">Kami mengutamakan hasil terbaik di setiap detail, didukung layanan yang mudah dan responsif.</p>
          <a href="/kontak" aria-label="Hubungi Lanyard Depok" class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[var(--primary-foreground)] text-[var(--primary)] shadow-sm transition hover:scale-105 focus:outline-none focus:ring-2 focus:ring-[var(--primary-foreground)]/70">
            <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </article>
      <div class="grid gap-5 md:grid-cols-2">
        {benefitItems.map((item) => (
          <article class="flex min-h-[10rem] items-center gap-6 rounded-2xl border border-[var(--border)] bg-[var(--card)] p-7 shadow-xs sm:min-h-[11rem] sm:p-8">
            <div class="grid h-16 w-16 shrink-0 place-items-center rounded-full bg-[var(--secondary)] text-[var(--primary)]">
              {item.icon === 'printer' && (
                <svg aria-hidden="true" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V3h12v6"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 14h12v7H6z"/><path d="M18 12h.01"/></svg>
              )}
              {item.icon === 'clipboard' && (
                <svg aria-hidden="true" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5h6"/><path d="M9 3h6v4H9z"/><path d="M16 5h2a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-5"/></svg>
              )}
              {item.icon === 'pen' && (
                <svg aria-hidden="true" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="m12 20 9-9-4-4-9 9-2 6z"/><path d="m15 9 4 4"/><path d="M6 4v4"/><path d="M4 6h4"/><path d="M18 16v3"/><path d="M16.5 17.5h3"/></svg>
              )}
              {item.icon === 'refresh' && (
                <svg aria-hidden="true" class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 1-15.5 6.2"/><path d="M3 12A9 9 0 0 1 18.5 5.8"/><path d="M18 2v4h4"/><path d="M6 22v-4H2"/></svg>
              )}
            </div>
            <div class="min-w-0">
              <h3 class="text-lg font-bold leading-tight tracking-normal text-[var(--foreground)]">{item.title}</h3>
              <p class="mt-3 max-w-[15rem] text-sm leading-6 text-[var(--muted-foreground)]">{item.description}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-[var(--border)] bg-white py-20 text-[var(--foreground)] sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.82fr_1.18fr] lg:gap-12 lg:px-8">
      <div class="flex min-w-0 flex-col">
        <div>
          <p class="text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary)]">Pilihan Produk</p>
          <h2 class="mt-6 max-w-xl text-[2rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[2.4rem] lg:text-[2.75rem]">Beragam pilihan untuk <span class="text-[var(--primary)]">kebutuhan Anda.</span></h2>
          <p class="mt-4 max-w-md text-base leading-7 text-[var(--muted-foreground)]">Temukan lanyard yang sesuai dengan acara, identitas, dan kebutuhan Anda.</p>
          <a href="/produk" style="color: var(--primary-foreground)" class="mt-8 inline-flex min-h-12 items-center justify-center gap-4 rounded-full bg-[var(--primary)] px-7 text-sm font-bold shadow-sm transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2 focus:ring-offset-[var(--background)]">
            <span>Lihat Semua Produk</span>
            <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
