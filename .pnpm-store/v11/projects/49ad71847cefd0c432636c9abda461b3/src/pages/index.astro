          <a class="btn-secondary" href="/produk">Lihat Produk</a>
        </div>
      </div>
      <div class="relative mx-auto flex w-full max-w-full snap-x gap-3 overflow-x-auto pb-4 sm:block sm:h-[520px] sm:max-w-[620px] sm:overflow-visible sm:pb-0 lg:max-w-none">
        <div aria-hidden="true" class="hidden sm:block absolute left-[8%] top-[12%] z-20 rounded-full border border-[var(--border)] bg-white/90 px-3 py-1.5 text-xs font-bold text-[var(--primary)] shadow-sm backdrop-blur">Sublimasi</div>
        <div aria-hidden="true" class="hidden sm:block absolute right-[6%] top-[18%] z-20 rounded-full border border-[var(--border)] bg-white/90 px-3 py-1.5 text-xs font-bold text-[var(--primary)] shadow-sm backdrop-blur">Polyester</div>
        <div aria-hidden="true" class="hidden sm:block absolute bottom-[15%] left-[28%] z-20 rounded-full border border-[var(--border)] bg-white/90 px-3 py-1.5 text-xs font-bold text-[var(--primary)] shadow-sm backdrop-blur">Custom logo</div>

        <div class="relative h-72 w-[78vw] shrink-0 snap-center overflow-hidden rounded-2xl bg-[var(--card)] shadow-xl ring-1 ring-[var(--border)] sm:absolute sm:left-1/2 sm:top-0 sm:h-72 sm:w-72 sm:-translate-x-1/2">
          <img class="h-full w-full object-cover" src={mediaUrl('/uploads/hero-lanyard-slider-01.webp')} alt="Contoh lanyard custom untuk perusahaan dan event" fetchpriority="high" decoding="async" />
        </div>

        <div class="relative h-72 w-[78vw] shrink-0 snap-center overflow-hidden rounded-2xl bg-[var(--card)] shadow-xl ring-1 ring-[var(--border)] sm:absolute sm:right-0 sm:top-[32%] sm:h-60 sm:w-60">
          <img class="h-full w-full object-cover" src={mediaUrl('/uploads/hero-lanyard-slider-02.webp')} alt="Detail bahan tali lanyard custom" decoding="async" />
        </div>

        <div class="relative h-72 w-[78vw] shrink-0 snap-center overflow-hidden rounded-2xl bg-[var(--card)] shadow-xl ring-1 ring-[var(--border)] sm:absolute sm:bottom-0 sm:left-0 sm:h-56 sm:w-56">
          <img class="h-full w-full object-cover" src={mediaUrl('/uploads/hero-lanyard-slider-03.webp')} alt="Pilihan desain lanyard custom Lanyard Depok" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-[var(--border)] bg-white py-20 sm:py-24">
    <div class="mx-auto flex max-w-7xl flex-col items-center gap-8 px-4 text-center sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary)]">Partner & Klien</p>
        <h2 class="mt-4 text-[2rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[2.4rem] lg:text-[2.75rem]">Dipercaya Brand &amp; Instansi</h2>
        <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-[var(--muted-foreground)]">Dipilih untuk kebutuhan lanyard custom perusahaan, sekolah, komunitas, dan event.</p>
      </div>

      <div class="grid w-full max-w-5xl grid-cols-2 justify-items-center gap-3 sm:gap-4 md:hidden" data-partner-logo-grid>
        {partnerLogoMobileColumns.map((columnLogos, columnIndex) => (
          <div class="partner-logo-card" data-partner-logo-card data-column-index={columnIndex} style={`--partner-column-index: ${columnIndex}`}>
            {columnLogos.map((logo, logoIndex) => (
              logo.href ? (
                <a
                  href={logo.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={logo.name}
                  class:list={['partner-logo-slot', logoIndex === 0 && 'is-active']}
                  data-logo-slot
                  tabindex={logoIndex === 0 ? undefined : '-1'}
                >
                  <img class="partner-logo-image" src={mediaUrl(logo.src)} alt={logo.alt} width={logo.width} height={logo.height} loading="lazy" />
                </a>
              ) : (
                <span class:list={['partner-logo-slot', logoIndex === 0 && 'is-active']} data-logo-slot>
                  <img class="partner-logo-image" src={mediaUrl(logo.src)} alt={logo.alt} width={logo.width} height={logo.height} loading="lazy" />
                </span>
              )
            ))}
          </div>
        ))}
      </div>

      <div class="hidden w-full max-w-5xl justify-items-center gap-4 md:grid md:grid-cols-5" data-partner-logo-grid>
        {partnerLogoDesktopColumns.map((columnLogos, columnIndex) => (
          <div class="partner-logo-card" data-partner-logo-card data-column-index={columnIndex} style={`--partner-column-index: ${columnIndex}`}>
            {columnLogos.map((logo, logoIndex) => (
              logo.href ? (
                <a
                  href={logo.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={logo.name}
                  class:list={['partner-logo-slot', logoIndex === 0 && 'is-active']}
                  data-logo-slot
                  tabindex={logoIndex === 0 ? undefined : '-1'}
                >
                  <img class="partner-logo-image" src={mediaUrl(logo.src)} alt={logo.alt} width={logo.width} height={logo.height} loading="lazy" />
                </a>
              ) : (
                <span class:list={['partner-logo-slot', logoIndex === 0 && 'is-active']} data-logo-slot>
                  <img class="partner-logo-image" src={mediaUrl(logo.src)} alt={logo.alt} width={logo.width} height={logo.height} loading="lazy" />
                </span>
              )
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <script>
    const reduceLogoMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const logoCards = Array.from(document.querySelectorAll('[data-partner-logo-card]'));

    if (!reduceLogoMotion.matches) {
      const logoCardStates = logoCards.map((card) => {
        const slots = Array.from(card.querySelectorAll('[data-logo-slot]'));
        let activeIndex = slots.findIndex((slot) => slot.classList.contains('is-active'));
        if (activeIndex < 0) activeIndex = 0;

        return {
          card,
          slots,
          activeIndex,
          columnIndex: Number(card.getAttribute('data-column-index') || 0),
          exitTimer: 0,
        };
      }).filter((state) => state.slots.length > 1);

      const setLogoSlot = (state, nextIndex) => {
        const { slots } = state;
        if (slots.length < 2 || nextIndex === state.activeIndex) return;

        const previousSlot = slots[state.activeIndex];
        const nextSlot = slots[nextIndex];

        previousSlot.classList.remove('is-active');
        previousSlot.classList.add('is-exiting');
        if (previousSlot instanceof HTMLAnchorElement) previousSlot.tabIndex = -1;

        nextSlot.classList.add('is-active');
        nextSlot.classList.remove('is-exiting');
        if (nextSlot instanceof HTMLAnchorElement) nextSlot.removeAttribute('tabindex');

        state.activeIndex = nextIndex;
        window.clearTimeout(state.exitTimer);
        state.exitTimer = window.setTimeout(() => {
          previousSlot.classList.remove('is-exiting');
        }, 300);
      };

      let currentTime = 0;
      const cycleInterval = 2000;

      window.setInterval(() => {
        currentTime += 100;

        logoCardStates.forEach((state) => {
          const adjustedTime = (currentTime + state.columnIndex * 200) % (cycleInterval * state.slots.length);
          const nextIndex = Math.floor(adjustedTime / cycleInterval);
          setLogoSlot(state, nextIndex);
        });
      }, 100);
    }
  </script>
  <section class="border-b border-[var(--border)] bg-white py-20 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-5 px-4 sm:px-6 lg:grid-cols-[0.95fr_1.95fr] lg:px-8">
      <article class="relative flex min-h-[20rem] flex-col overflow-hidden rounded-2xl bg-[var(--primary)] p-8 text-[var(--primary-foreground)] shadow-sm sm:p-10">
