        </div>

        <div class="mt-16 lg:mt-20">
          <div class="relative aspect-[4/3] min-h-[15rem] sm:min-h-[18rem]">
            <img class="h-full w-full object-contain" src={mediaUrl('/uploads/featured-products-showcase-lanyarddepok-v2.webp')} alt="Pilihan lanyard custom Lanyard Depok" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>

      <div class="grid gap-3">
        {showcaseItems.length > 0 ? showcaseItems.map((product, index) => (
          <a href={product.href} class="featured-product-card group grid overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)] transition hover:-translate-y-0.5 hover:border-[color-mix(in_srgb,var(--primary)_40%,var(--border))] md:grid-cols-[0.85fr_1fr]">
            <div class="relative min-h-[9rem] overflow-hidden md:min-h-[7.5rem]">
              <img class="absolute inset-0 h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]" src={mediaUrl(product.image)} alt={product.title} loading="lazy" decoding="async" />
            </div>

            <div class="flex min-h-[7.5rem] items-center gap-4 p-4 sm:p-5">
              <div class="min-w-0 flex-1">
                <div class="text-lg font-extrabold leading-none text-[var(--primary)]">{String(index + 1).padStart(2, '0')}</div>
                <span class="mt-2.5 block h-0.5 w-7 rounded-full bg-[var(--primary)]"></span>
                <h3 class="mt-3 text-lg font-bold leading-tight tracking-normal text-[var(--foreground)]">{product.title}</h3>
                <p class="mt-2 max-w-sm text-xs leading-5 text-[var(--muted-foreground)]">{product.description}</p>
              </div>
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[var(--primary)] text-[var(--primary)] transition group-hover:bg-[var(--primary)] group-hover:text-[var(--primary-foreground)]">
                <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        )) : (
          <div class="rounded-2xl border border-[var(--border)] bg-[var(--card)] p-8 text-sm leading-6 text-[var(--muted-foreground)]">
            Produk belum tersedia dari API. Jalankan sinkronisasi produk di dashboard admin agar data spreadsheet tampil di section ini.
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="border-b border-[var(--border)] bg-white py-20 text-[var(--foreground)] sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-8 max-w-3xl text-center">
        <p class="text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary)]">Testimoni Klien</p>
        <h2 class="mt-6 text-[2rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[2.4rem] lg:text-[2.75rem]">Dipercaya untuk kebutuhan lanyard berbagai instansi.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-[var(--muted-foreground)]">Cerita singkat dari klien yang memakai lanyard custom untuk event, identitas tim, dan kebutuhan branding.</p>
      </div>

      <div class="overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)] text-[var(--foreground)]" data-testimonial-slider data-active-index="0">
        <div class="grid gap-6 p-5 sm:p-6 lg:grid-cols-[0.72fr_1fr_1.15fr] lg:gap-8 lg:p-7">
          <div class="order-3 flex flex-col justify-between gap-5 lg:order-1">
            <div>
              <p class="text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary)]">Testimoni</p>
              <p class="mt-3 text-2xl font-extrabold leading-none text-[var(--foreground)]">
                <span data-testimonial-current>{String(1).padStart(2, '0')}</span>
                <span class="mx-2 text-[var(--muted-foreground)]">/</span>
                <span class="text-[var(--muted-foreground)]">{String(testimonialSliderReviews.length).padStart(2, '0')}</span>
              </p>
            </div>

            <div class="flex gap-2 overflow-x-auto pb-1 lg:flex-wrap lg:overflow-visible" data-testimonial-thumbnails>
              {testimonialSliderReviews.map((review, index) => (
                <button
                  type="button"
                  class:list={[
                    'relative h-16 w-14 shrink-0 overflow-hidden rounded-xl border border-[var(--border)] bg-[var(--background)] transition hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2 focus:ring-offset-[var(--background)] sm:h-20 sm:w-16',
                    index === 0 ? 'opacity-100 ring-2 ring-[var(--primary)]' : 'opacity-70',
                  ]}
                  aria-label={`Lihat testimoni ${review.name}`}
                  aria-pressed={index === 0 ? 'true' : 'false'}
                  data-testimonial-thumb
                  data-testimonial-index={index}
                >
                  <img class="absolute inset-0 h-full w-full object-cover" src={review.thumbnailSrc} alt={review.name} loading="lazy" decoding="async" />
                </button>
              ))}
            </div>
          </div>

          <div class="relative order-1 min-h-[18rem] overflow-hidden rounded-2xl bg-[var(--background)] lg:order-2 lg:min-h-[22rem]">
            <img class="absolute inset-0 h-full w-full object-cover transition duration-300" src={testimonialSliderReviews[0].imageSrc} alt={testimonialSliderReviews[0].name} loading="lazy" decoding="async" data-testimonial-image />
          </div>

          <div class="order-2 flex min-h-[15rem] flex-col justify-between gap-8 lg:order-3">
            <div class="min-h-[12rem] overflow-hidden">
              <div class="transition duration-300" data-testimonial-copy>
                <p class="text-sm font-bold text-[var(--primary)]" data-testimonial-affiliation>{testimonialSliderReviews[0].affiliation}</p>
                <h3 class="mt-2 text-2xl font-bold leading-tight tracking-normal text-[var(--foreground)]" data-testimonial-name>{testimonialSliderReviews[0].name}</h3>
                <blockquote class="mt-5 max-w-xl text-xl font-normal leading-[1.35] tracking-normal text-[var(--foreground)] sm:text-2xl" data-testimonial-quote>"{testimonialSliderReviews[0].quote}"</blockquote>
              </div>
            </div>

            <div class="flex items-center gap-3">
              <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-[var(--primary)] text-[var(--primary)] transition hover:bg-[var(--secondary)] focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2 focus:ring-offset-[var(--background)]" aria-label="Testimoni sebelumnya" data-testimonial-prev>
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
              </button>
              <button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[var(--primary)] text-[var(--primary-foreground)] transition hover:opacity-90 focus:outline-none focus:ring-2 focus:ring-[var(--primary)] focus:ring-offset-2 focus:ring-offset-[var(--background)]" aria-label="Testimoni berikutnya" data-testimonial-next>
                <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ testimonialReviews: testimonialSliderReviews }}>
    const testimonialSlider = document.querySelector('[data-testimonial-slider]');

    if (testimonialSlider && testimonialReviews.length > 0) {
      const reduceTestimonialMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const currentNode = testimonialSlider.querySelector('[data-testimonial-current]');
      const imageNode = testimonialSlider.querySelector('[data-testimonial-image]');
      const copyNode = testimonialSlider.querySelector('[data-testimonial-copy]');
      const affiliationNode = testimonialSlider.querySelector('[data-testimonial-affiliation]');
      const nameNode = testimonialSlider.querySelector('[data-testimonial-name]');
      const quoteNode = testimonialSlider.querySelector('[data-testimonial-quote]');
      const thumbNodes = Array.from(testimonialSlider.querySelectorAll('[data-testimonial-thumb]'));
      const previousButton = testimonialSlider.querySelector('[data-testimonial-prev]');
      const nextButton = testimonialSlider.querySelector('[data-testimonial-next]');
      let activeTestimonialIndex = Number(testimonialSlider.dataset.activeIndex || 0);

      const formatTestimonialNumber = (value) => String(value).padStart(2, '0');

      const setCopyOpacity = (opacity) => {
        if (copyNode instanceof HTMLElement) copyNode.style.opacity = String(opacity);
        if (imageNode instanceof HTMLElement) imageNode.style.opacity = String(opacity);
      };

      const renderTestimonial = (index) => {
        activeTestimonialIndex = (index + testimonialReviews.length) % testimonialReviews.length;
        testimonialSlider.dataset.activeIndex = String(activeTestimonialIndex);
        const activeReview = testimonialReviews[activeTestimonialIndex];

        if (currentNode) currentNode.textContent = formatTestimonialNumber(activeTestimonialIndex + 1);
        if (imageNode instanceof HTMLImageElement) {
          imageNode.src = activeReview.imageSrc;
          imageNode.alt = activeReview.name;
        }
        if (affiliationNode) affiliationNode.textContent = activeReview.affiliation;
        if (nameNode) nameNode.textContent = activeReview.name;
        if (quoteNode) quoteNode.textContent = `"${activeReview.quote}"`;

        thumbNodes.forEach((thumb, thumbIndex) => {
          const isActive = thumbIndex === activeTestimonialIndex;
          thumb.classList.toggle('opacity-100', isActive);
          thumb.classList.toggle('opacity-70', !isActive);
          thumb.classList.toggle('ring-2', isActive);
          thumb.classList.toggle('ring-[var(--primary)]', isActive);
          thumb.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      const showTestimonial = (index) => {
        if (reduceTestimonialMotion.matches) {
          renderTestimonial(index);
          return;
        }

        setCopyOpacity(0);
        window.setTimeout(() => {
          renderTestimonial(index);
          setCopyOpacity(1);
        }, 160);
      };

      previousButton?.addEventListener('click', () => showTestimonial(activeTestimonialIndex - 1));
      nextButton?.addEventListener('click', () => showTestimonial(activeTestimonialIndex + 1));
      thumbNodes.forEach((thumb) => {
        thumb.addEventListener('click', () => {
          const index = Number(thumb.getAttribute('data-testimonial-index'));
          if (Number.isFinite(index) && index !== activeTestimonialIndex) showTestimonial(index);
        });
      });

      renderTestimonial(activeTestimonialIndex);
    }
  </script>

  <section class="border-b border-[var(--border)] bg-white py-20 text-[var(--foreground)] sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 sm:px-6 lg:grid-cols-[0.86fr_1.14fr] lg:gap-12 lg:px-8">
      <div class="flex min-w-0 flex-col">
        <div>
          <p class="text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary)]">Pertanyaan Umum</p>
          <h2 class="mt-6 max-w-xl text-[2rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[2.4rem] lg:text-[2.75rem]">Hal yang sering ditanyakan sebelum pesan lanyard custom.</h2>
          <p class="mt-4 max-w-md text-base leading-7 text-[var(--muted-foreground)]">Jawaban singkat seputar proses pemesanan, produksi, desain, pembayaran, dan garansi.</p>
        </div>

        <div class="mt-10 overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)]">
          <div class="relative aspect-[4/3] min-h-[15rem]">
            <img class="absolute inset-0 h-full w-full object-cover" src={mediaUrl('/uploads/pengiriman-packaging-lanyarddepok.webp')} alt="Pengemasan dan pengiriman lanyard custom Lanyard Depok" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>

      <div class="grid content-start gap-3" data-faq-accordion>
        {faqItems.map((item, index) => {
          const isOpen = index === 0;
          const contentId = `homepage-faq-content-${index}`;

          return (
            <article class="overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)]" data-faq-item>
              <button
                type="button"
                class="flex w-full items-center justify-between gap-5 p-5 text-left sm:p-6"
                aria-expanded={isOpen ? 'true' : 'false'}
                aria-controls={contentId}
                data-faq-button
              >
                <span class="text-base font-extrabold leading-snug tracking-normal text-[var(--foreground)] sm:text-lg">{item.question}</span>
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-[var(--primary)] text-[var(--primary)]">
                  <svg aria-hidden="true" class:list={['h-5 w-5 transition-transform duration-300', isOpen && 'rotate-180']} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-faq-chevron><path d="m6 9 6 6 6-6"/></svg>
                </span>
              </button>

              <div id={contentId} class:list={['grid transition-all duration-300 ease-out', isOpen ? 'grid-rows-[1fr]' : 'grid-rows-[0fr]']} data-faq-panel>
                <div class="overflow-hidden">
                  <p class="border-t border-[var(--border)] px-5 py-5 text-sm leading-6 text-[var(--muted-foreground)] sm:px-6">{item.answer}</p>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <script>
    const faqAccordion = document.querySelector('[data-faq-accordion]');

    if (faqAccordion) {
      const faqItems = Array.from(faqAccordion.querySelectorAll('[data-faq-item]'));

      const setFaqItemOpen = (item, isOpen) => {
        const button = item.querySelector('[data-faq-button]');
        const panel = item.querySelector('[data-faq-panel]');
        const chevron = item.querySelector('[data-faq-chevron]');

        button?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        panel?.classList.toggle('grid-rows-[1fr]', isOpen);
        panel?.classList.toggle('grid-rows-[0fr]', !isOpen);
        chevron?.classList.toggle('rotate-180', isOpen);
      };

      faqItems.forEach((item) => {
        const button = item.querySelector('[data-faq-button]');
        button?.addEventListener('click', () => {
          const isOpen = button.getAttribute('aria-expanded') === 'true';

          faqItems.forEach((faqItem) => setFaqItemOpen(faqItem, false));
          setFaqItemOpen(item, !isOpen);
        });
      });
    }
  </script>

  <style>
    .partner-logo-card {
      align-items: center;
      animation: partner-logo-card-in 450ms ease-out forwards;
      animation-delay: calc(var(--partner-column-index, 0) * 80ms);
      background: color-mix(in srgb, var(--card) 70%, transparent);
      border: 1px solid var(--border);
      border-radius: 0.75rem;
      display: flex;
      height: 4rem;
      justify-content: center;
      overflow: hidden;
      position: relative;
      opacity: 0;
      transform: translateY(28px);
      width: 8rem;
      transition:
        border-color 180ms ease,
        box-shadow 180ms ease;
    }

    .partner-logo-card:hover {
      border-color: color-mix(in srgb, var(--primary) 36%, var(--border));
      box-shadow: 0 16px 40px rgb(31 31 31 / 8%);
    }

    .partner-logo-slot {
      align-items: center;
      display: flex;
      filter: blur(8px);
      inset: 0;
      justify-content: center;
      opacity: 0;
      padding: 0 1rem;
      pointer-events: none;
      position: absolute;
      transform: translateY(10%);
      transition:
        filter 500ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 500ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 500ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .partner-logo-slot.is-active {
      filter: blur(0);
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .partner-logo-slot.is-exiting {
      filter: blur(6px);
      opacity: 0;
      transform: translateY(-20%);
      transition:
        filter 300ms ease-in,
        opacity 300ms ease-in,
        transform 300ms ease-in;
    }

    .partner-logo-image {
      filter: grayscale(1);
      height: auto;
      max-height: 70%;
      max-width: 78%;
      object-fit: contain;
      opacity: 0.75;
      transition:
        filter 300ms ease,
        opacity 300ms ease;
      width: auto;
    }

    .partner-logo-slot:hover .partner-logo-image,
    .partner-logo-slot:focus-visible .partner-logo-image {
      filter: grayscale(0);
      opacity: 1;
    }

    @media (min-width: 768px) {
      .partner-logo-card {
        height: 6rem;
        width: 12rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .partner-logo-card {
        animation: none;
        opacity: 1;
        transform: none;
      }

      .partner-logo-slot {
        filter: none;
        transition: none;
        transform: none;
      }

      .partner-logo-slot:not(.is-active) {
        display: none;
      }

      .partner-logo-image {
        transition: none;
      }
    }

    @keyframes partner-logo-card-in {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</PublicLayout>
