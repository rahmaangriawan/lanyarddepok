      <div class="flex flex-col items-center text-center lg:items-start lg:text-left">
        <p class="mb-5 text-xs font-extrabold uppercase leading-5 tracking-normal text-[var(--primary)]">Lanyard Custom Depok</p>
        <h1 class="max-w-3xl text-4xl font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[3.2rem] lg:text-[3.2rem]">
