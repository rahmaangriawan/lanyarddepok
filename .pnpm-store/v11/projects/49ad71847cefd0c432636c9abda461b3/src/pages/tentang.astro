---
import PublicLayout from '../layouts/PublicLayout.astro';
import '../styles/tentang.css';

export const prerender = true;

const whatsappUrl =
  'https://wa.me/6282210200700?text=Halo%20Lanyard%20Depok%2C%20saya%20ingin%20konsultasi%20lanyard%20custom.';

const storyStats = [
  {
    title: '5+ Tahun',
    description: 'Berpengalaman',
    icon: 'flag',
  },
  {
    title: 'Ribuan Klien',
    description: 'Telah Puas',
    icon: 'users',
  },
  {
    title: 'Produksi Sendiri',
    description: 'Kualitas Terjaga',
    icon: 'box',
  },
];

const principles = [
  {
    title: 'Kualitas Tanpa Kompromi',
    description: 'Kami memilih bahan terbaik dan memastikan setiap detail rapi serta kuat.',
    icon: 'badge',
  },
  {
    title: 'Proses Efisien dan Tepat Waktu',
    description: 'Produksi terjadwal dengan baik agar pesanan selesai sesuai deadline Anda.',
    icon: 'clock',
  },
  {
    title: 'Pelayanan Ramah dan Responsif',
    description: 'Kami siap membantu dari proses konsultasi hingga after sales kapan pun dibutuhkan.',
    icon: 'headset',
  },
  {
    title: 'Amanah dan Terpercaya',
    description: 'Kepercayaan Anda adalah motivasi kami untuk selalu memberikan yang terbaik.',
    icon: 'shield',
  },
  {
    title: 'Solusi yang Fleksibel',
    description: 'Kebutuhan setiap klien berbeda, kami siap menyesuaikan dengan kebutuhan Anda.',
    icon: 'heart',
  },
];

const whyItems = [
  'Desain custom sesuai identitas brand',
  'Bahan berkualitas, nyaman dan awet',
  'Warna tajam, sablon & printing presisi',
  'Minimal order fleksibel',
  'Pengiriman cepat ke seluruh Indonesia',
];
---

<PublicLayout
  title="Tentang Kami Lanyard Depok"
  description="Kenali Lanyard Depok, penyedia lanyard custom berkualitas untuk brand, perusahaan, sekolah, komunitas, dan event."
>
  <section class="border-b border-[var(--border)] bg-[#FCF8F5] py-16 text-[var(--foreground)] sm:py-20 lg:py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-12 px-4 sm:px-6 lg:grid-cols-[1fr_0.92fr] lg:gap-14 lg:px-8">
      <div class="min-w-0">
        <p class="inline-flex items-center gap-3 rounded-full bg-[var(--muted)] px-5 py-3 text-sm font-bold text-[var(--primary)]">
          <svg aria-hidden="true" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M15 7a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
          Tentang Kami
        </p>

        <h1 class="mt-6 max-w-xl text-[2.65rem] font-bold leading-[1.07] tracking-normal text-[var(--foreground)] sm:text-[3.4rem] lg:text-[4rem]">
          Identitas kecil, Dampak besar untuk brand Anda.
        </h1>

        <div class="mt-7 max-w-xl space-y-5 text-base leading-7 text-[var(--muted-foreground)] sm:text-lg sm:leading-8">
          <p>
            Lanyard lebih dari sekadar tali gantung. Ini adalah representasi identitas, profesionalitas, dan kepercayaan yang Anda bawa setiap hari.
          </p>
          <p>
            LanyardDepok.com hadir untuk membantu Anda mewujudkan lanyard custom berkualitas tinggi dengan proses mudah, hasil memuaskan.
          </p>
        </div>

        <div class="mt-8">
          <a class="btn-primary gap-3" href={whatsappUrl} target="_blank" rel="noopener noreferrer">
            <span>Minta Quotation</span>
            <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="var(--primary-foreground)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="relative lg:justify-self-end">
        <div class="mx-auto max-w-[34rem] overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--card)] shadow-[0_18px_60px_rgba(112,77,64,0.08)] lg:mx-0">
          <img
            src="/uploads/cara-pemesanan-hero-lanyarddepok.webp"
            alt="Lanyard custom dan ID card Lanyard Depok"
            class="aspect-[1.22/1] w-full object-cover"
            width="980"
            height="640"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 text-[var(--foreground)] sm:py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 rounded-2xl border border-[var(--border)] bg-white/78 p-4 shadow-[0_18px_60px_rgba(112,77,64,0.05)] sm:p-6 lg:grid-cols-[0.86fr_1.14fr] lg:gap-10 lg:p-8">
        <div class="overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--muted)]">
          <img
            src="/uploads/tentang-cerita-kami-lanyarddepok.webp"
            alt="Packaging dan proses produksi lanyard Lanyard Depok"
            class="aspect-[1.18/1] h-full w-full object-cover"
            width="1448"
            height="1086"
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="flex min-w-0 flex-col justify-center py-2 lg:py-4">
          <p class="section-eyebrow">Cerita Kami</p>
          <h2 class="mt-4 max-w-xl text-[2rem] font-bold leading-[1.12] tracking-normal text-[var(--foreground)] sm:text-[2.55rem]">
            Berawal dari kebutuhan, berkomitmen pada kualitas.
          </h2>

          <div class="mt-6 max-w-2xl space-y-4 text-sm leading-7 text-[var(--muted-foreground)] sm:text-base sm:leading-8">
            <p>
              Kami memulai LanyardDepok.com dari pengalaman langsung di lapangan, melihat banyak brand dan instansi kesulitan mendapatkan lanyard custom yang rapi, kuat, dan tepat waktu.
            </p>
            <p>
              Karena itu, kami berkomitmen memberikan solusi terbaik melalui bahan pilihan, proses produksi yang teliti, dan pelayanan yang selalu mengutamakan kepuasan Anda.
            </p>
          </div>

          <div class="mt-8 grid gap-4 sm:grid-cols-3">
            {storyStats.map((stat) => (
              <div class="flex items-center gap-3">
                <div class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-[var(--secondary)] text-[var(--primary)]">
                  {stat.icon === 'flag' && (
                    <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M5 22V4"/><path d="M5 4c4-2 6 2 10 0 1.2-.6 2.3-.9 4-.6v10c-1.7-.3-2.8 0-4 .6-4 2-6-2-10 0"/></svg>
                  )}
                  {stat.icon === 'users' && (
                    <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-8 0v2"/><circle cx="12" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/><path d="M2 21v-2a4 4 0 0 1 3-3.87"/><path d="M8 3.13a4 4 0 0 0 0 7.75"/></svg>
                  )}
                  {stat.icon === 'box' && (
                    <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="m21 8-9-5-9 5 9 5z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg>
                  )}
                </div>
                <div class="min-w-0">
                  <p class="text-xs leading-5 text-[var(--muted-foreground)]">{stat.description}</p>
                  <p class="text-sm font-extrabold leading-tight text-[var(--foreground)]">{stat.title}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-16 text-[var(--foreground)] sm:py-20 lg:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="section-eyebrow">Apa Yang Kami Pegang</p>
        <h2 class="mx-auto mt-4 max-w-3xl text-[2rem] font-bold leading-[1.12] tracking-normal text-[var(--foreground)] sm:text-[2.7rem]">
          Prinsip sederhana yang selalu kami jaga.
        </h2>
        <div class="mx-auto mt-5 h-1 w-12 rounded-full bg-[var(--secondary)]"></div>
      </div>

      <div class="about-principles relative mt-12 grid gap-7 sm:grid-cols-2 lg:grid-cols-5 lg:gap-8">
        {principles.map((item) => (
          <article class="relative text-center">
            <div class="mx-auto grid h-20 w-20 place-items-center rounded-full bg-[var(--muted)] text-[var(--primary)] sm:h-24 sm:w-24">
              {item.icon === 'badge' && (
                <svg aria-hidden="true" class="h-9 w-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 8.8 6.2 4.4 6.8l.8 4.3L3 15l3.9 2 1.9 4 3.2-3.1 3.2 3.1 1.9-4 3.9-2-2.2-3.9.8-4.3-4.4-.6z"/><path d="M9.5 12.5 11 14l3.5-4"/></svg>
              )}
              {item.icon === 'clock' && (
                <svg aria-hidden="true" class="h-9 w-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
              )}
              {item.icon === 'headset' && (
                <svg aria-hidden="true" class="h-9 w-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12a8 8 0 0 1 16 0"/><path d="M4 12v3a2 2 0 0 0 2 2h1v-6H6a2 2 0 0 0-2 2Z"/><path d="M20 12v3a2 2 0 0 1-2 2h-1v-6h1a2 2 0 0 1 2 2Z"/><path d="M15 19c-1 1-2 1-3 1"/></svg>
              )}
              {item.icon === 'shield' && (
                <svg aria-hidden="true" class="h-9 w-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V5l8-3 8 3z"/><path d="m9 12 2 2 4-5"/></svg>
              )}
              {item.icon === 'heart' && (
                <svg aria-hidden="true" class="h-9 w-9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 1 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8Z"/></svg>
              )}
            </div>
            <h3 class="mx-auto mt-6 max-w-[13rem] text-base font-bold leading-tight text-[var(--foreground)]">{item.title}</h3>
            <p class="mx-auto mt-4 max-w-[14rem] text-sm leading-6 text-[var(--muted-foreground)]">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-16 text-[var(--foreground)] sm:py-20 lg:py-24">
    <div class="mx-auto grid max-w-7xl items-center gap-10 px-4 sm:px-6 lg:grid-cols-[0.88fr_1fr] lg:gap-12 lg:px-8">
      <div class="min-w-0">
        <p class="section-eyebrow">Mengapa Memilih</p>
        <h2 class="mt-4 max-w-lg text-[2.35rem] font-bold leading-[1.08] tracking-normal text-[var(--foreground)] sm:text-[3rem]">
          LanyardDepok.com?
        </h2>
        <div class="mt-5 h-1 w-12 rounded-full bg-[var(--secondary)]"></div>
        <p class="mt-7 max-w-md text-base leading-7 text-[var(--muted-foreground)]">
          Kami tidak hanya menjual lanyard, kami membantu brand Anda tampil lebih profesional dan berkesan.
        </p>

        <ul class="mt-7 space-y-4">
          {whyItems.map((item) => (
            <li class="flex items-start gap-3 text-sm font-bold leading-6 text-[var(--foreground)] sm:text-base">
              <span class="mt-1 grid h-5 w-5 shrink-0 place-items-center rounded-full bg-[var(--primary)] text-[var(--primary-foreground)]">
                <svg aria-hidden="true" class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m5 12 4 4L19 6"/></svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="relative mx-auto w-full max-w-[42rem] overflow-hidden rounded-2xl border border-[var(--border)] bg-white shadow-[0_18px_60px_rgba(112,77,64,0.07)] lg:mr-0">
        <img
          src="/uploads/tentang-mengapa-memilih-lanyarddepok.webp"
          alt="Pilihan lanyard custom Lanyard Depok"
          class="aspect-[1.42/1] w-full object-cover"
          width="1448"
          height="1086"
          loading="lazy"
          decoding="async"
        />
        <div class="absolute bottom-4 left-4 max-w-[21rem] rounded-2xl border border-[var(--border)] bg-white/92 p-4 shadow-xl backdrop-blur sm:bottom-7 sm:left-7 sm:p-5">
          <div class="flex items-center gap-4">
            <div class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-[var(--primary)] text-[var(--primary-foreground)]">
              <svg aria-hidden="true" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7 9 18l-5-5"/><path d="M14 7h6v6"/></svg>
            </div>
            <p class="text-sm font-bold leading-6 text-[var(--foreground)]">
              Dari bahan hingga pengiriman, semua kami kendalikan untuk hasil yang bisa Anda andalkan.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    @media (min-width: 1024px) {
      .about-principles::before {
        background-image: repeating-linear-gradient(
          90deg,
          rgba(112, 77, 64, 0.28) 0 5px,
          transparent 5px 12px
        );
        content: "";
        height: 1px;
        left: 9%;
        position: absolute;
        right: 9%;
        top: 3rem;
      }

      .about-principles article {
        z-index: 1;
      }
    }
  </style>
</PublicLayout>
