# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules
**/vendor
!apps/backend/public/vendor/
!apps/backend/public/vendor/**
/.pnp
.pnp.*
.pnpm-store/
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
/src/generated/client
/scratch
apps/backend/storage/*.key
apps/backend/storage/logs/*.log
apps/backend/database/database.sqlite
apps/backend/public/storage
apps/backend/public/build
apps/frontend/dist

# local-only deploy notes and database/archive files
/lanyardjakarta.sql
/lanyarddepok.sql
/favicon.zip
